# ─── Serveur ───────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Sécurité JWT ──────────────────────────────────────────────────────────
# IMPORTANT : Changez cette clé avant le déploiement !
# Générez-en une avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGEZ_CETTE_CLE_AVANT_DEPLOIEMENT_utiliser_une_vraie_cle_aleatoire_de_64_caracteres
JWT_EXPIRES_IN=8h

# ─── Base de données ───────────────────────────────────────────────────────
DB_PATH=./data/mrdpstock.db

# ─── CORS ──────────────────────────────────────────────────────────────────
# URL du frontend (en production, même domaine = laisser vide)
CORS_ORIGIN=http://localhost:5173

# ─── Sessions ──────────────────────────────────────────────────────────────
# Durée d'inactivité avant déconnexion automatique (en minutes)
SESSION_TIMEOUT_MINUTES=480
